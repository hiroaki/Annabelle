# To disable Rack::Attack entirely, set ENABLED_RACK_ATTACK to 0.
# Default values: GET/HEAD 300 requests and write requests 60 requests per 60 seconds.
# IPs probing /.env or /.env.* are banned for 600 seconds.
#ENABLED_RACK_ATTACK=1
#RACK_ATTACK_GET_THROTTLE_LIMIT=300
#RACK_ATTACK_WRITE_THROTTLE_LIMIT=60
#RACK_ATTACK_THROTTLE_PERIOD_SECONDS=60
#RACK_ATTACK_BAN_DURATION_SECONDS=600
